{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    // TS 6 defaults `types` to [] (no ambient auto-include). Node globals
    // (process, Buffer, __dirname) currently survive only via next-env.d.ts's
    // generated reference chain (next → node) — declare node explicitly so a
    // future Next scaffolding change can't silently drop them.
    "types": ["node"],
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    ".next-verify/types/**/*.ts",
    ".next-verify/dev/types/**/*.ts",
    ".next-stage/types/**/*.ts",
    ".next-stage/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
