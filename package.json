{
  "name": "beta",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "NEXT_DIST_DIR=.next-verify next build --webpack",
    "start": "next start",
    "deploy": "node -e \"require('fs').writeFileSync('.deploy-id', Date.now().toString(36))\" && NEXT_DIST_DIR=.next-stage next build --webpack && rm -rf .next.old && mv .next .next.old && mv .next-stage .next && pm2 restart kalfa-beta && rm -rf .next.old && npm run worker:build && pm2 restart kalfa-worker",
    "worker:build": "esbuild worker/main.ts --bundle --platform=node --format=cjs --target=node20 --outfile=dist/worker.cjs --tsconfig=tsconfig.json --alias:server-only=./worker/empty.js --alias:next/headers=./worker/empty.js --alias:next/cache=./worker/empty.js --external:pg-native",
    "worker:start": "node dist/worker.cjs",
    "worker:logs": "pm2 logs kalfa-worker --lines 100",
    "pm2:restart": "pm2 restart kalfa-beta",
    "pm2:reload": "pm2 reload kalfa-beta",
    "pm2:status": "pm2 status kalfa-beta",
    "pm2:logs": "pm2 logs kalfa-beta --lines 100",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:db": "node --env-file=.env.local scripts/verify-db-contracts.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@cantoo/pdf-lib": "^2.7.1",
    "@hookform/resolvers": "^5.4.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@types/nodemailer": "^8.0.1",
    "@zxcvbn-ts/core": "^4.1.2",
    "@zxcvbn-ts/language-common": "^4.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jsonwebtoken": "^9.0.3",
    "libphonenumber-js": "^1.13.7",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "nodemailer": "^9.0.1",
    "pg-boss": "^12.21.2",
    "puppeteer": "^25.2.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.80.0",
    "recharts": "^3.8.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.11.0",
    "signature_pad": "^5.1.3",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "whatsapp-api-js": "^6.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "esbuild": "^0.28.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "supabase": "^2.109.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "puppeteer@25.2.1": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true
  }
}
