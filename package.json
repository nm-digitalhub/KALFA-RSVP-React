{
  "name": "beta",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "NEXT_DIST_DIR=.next-verify next build --webpack",
    "build:prod": "next build --webpack",
    "start": "next start",
    "deploy": "NEXT_DIST_DIR=.next-stage next build --webpack && rm -rf .next.old && mv .next .next.old && mv .next-stage .next && pm2 restart kalfa-beta --update-env && rm -rf .next.old",
    "pm2:restart": "pm2 restart kalfa-beta --update-env",
    "pm2:reload": "pm2 reload kalfa-beta --update-env",
    "pm2:status": "pm2 status kalfa-beta",
    "pm2:logs": "pm2 logs kalfa-beta --lines 100",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
