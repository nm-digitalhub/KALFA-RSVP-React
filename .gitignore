# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
# isolated verification/staging builds + ad-hoc NEXT_DIST_DIR=.next-<label>
/.next-*/
/.next.old/
# manual pre-deploy backup (rename of .next; not used by the deploy script)
/.next.rollback/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...but the documented example template should be committed
!.env.example

# vercel
.vercel

# claude code session data — EXCEPT project agents + skills, which are team
# assets shared via git (official project-subagent convention)
.remember/
.claude/*
!.claude/agents/
!.claude/skills/

# installed agent skills (tooling — reinstallable via `npx skills`; tracked via skills-lock.json)
.agents/skills/

# skills-CLI symlink farm for other agent runtimes (machine-local, regenerable)
.hermes/

# typescript
*.tsbuildinfo
next-env.d.ts
dist/
# Voximplant service-account keys + voxengine-ci config (NEVER commit — RSA private key inside)
voxi_auth.json
vox_ci_credentials.json
*vox*credentials*.json
voximplant-ci/voximplant.json
storage_state.json

# per-deploy version-skew id (written by npm run deploy)
/.deploy-id
*.swp

# local scratch (downloaded reports etc.)
/tmp/

# personal tax certificate (PII: ID number + home address) — NEVER commit
/taxes.pdf
