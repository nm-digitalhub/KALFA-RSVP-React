        "agent": {
            "first_message": "היי, {{guest_name}}? … כאן מיכל, בנוגע ל{{event_name}}.",
            "language": "he",
            "hinglish_mode": false,
            "dynamic_variables": {
                "dynamic_variable_placeholders": {
                    "event_name": "",
                    "guest_name": "",
