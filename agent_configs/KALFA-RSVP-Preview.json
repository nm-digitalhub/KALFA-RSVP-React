        "agent": {
            "first_message": "היי, {{guest_name}}? … זו מיכל, לגבי אישורי הגעה.",
            "language": "he",
            "hinglish_mode": false,
            "dynamic_variables": {
                "dynamic_variable_placeholders": {
                    "event_name": "",
                    "guest_name": "",
                    "event_date": "",
                    "event_venue": ""
