# Supabase — public values (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase — service role key (SERVER ONLY).
# Never expose via NEXT_PUBLIC_*, never commit a real value, never log it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# SUMIT Payments — https://app.sumit.co.il
NEXT_PUBLIC_SUMIT_COMPANY_ID=      # integer — ציבורי, נדרש ב-BindFormSubmit
NEXT_PUBLIC_SUMIT_API_PUBLIC_KEY=  # string  — ציבורי, נדרש ב-BindFormSubmit
SUMIT_API_KEY=                     # SERVER ONLY — לחיוב מהשרת. לעולם לא ל-NEXT_PUBLIC_
# createAdminClient() זורק אם SUPABASE_SERVICE_ROLE_KEY הוא placeholder; אין בדיקת פורמט —
# כל מפתח שרת תקין מתקבל. מומלץ מפתח חדש sb_secret_... (Settings → API Keys),
# או legacy service_role JWT (Settings → API). SERVER ONLY — לעולם לא NEXT_PUBLIC_, לא ל-Git.

# APP_ORIGIN — SERVER ONLY — לבדיקת CSRF. לא NEXT_PUBLIC_.
APP_ORIGIN=                        # למשל https://beta.kalfa.me
